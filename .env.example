# OpenAI — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# Tavily
TAVILY_API_KEY=tvly-REPLACE_ME

# Gradium TTS
GRADIUM_API_KEY=REPLACE_ME
GRADIUM_BASE_URL=https://api.gradium.example/v1

# fal.ai
FAL_API_KEY=REPLACE_ME
FAL_MODEL=fal-ai/flux/schnell

# Voice mapping (one Gradium voice id per host name, comma-separated key=value)
VOICE_MAP=Claire=voice_fr_female_1,Marc=voice_fr_male_1,Léa=voice_fr_female_2,Sofia=voice_fr_female_3,Tom=voice_fr_male_2,Inès=voice_fr_female_4,Hugo=voice_fr_male_3

# Paths
PROGRAMME_PATH=./programme.json
MEDIA_DIR=./media
TIMEZONE=Europe/Paris
