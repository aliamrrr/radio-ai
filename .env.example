# ══════════════════════════════════════════════════════════════
#  AI Radio — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════

# ── AI APIs (pipeline) ────────────────────────────────────────
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

TAVILY_API_KEY=tvly-REPLACE_ME

GRADIUM_API_KEY=REPLACE_ME
GRADIUM_BASE_URL=https://api.gradium.ai

FAL_API_KEY=REPLACE_ME
FAL_MODEL=fal-ai/flux/schnell

# ── Voice mapping ─────────────────────────────────────────────
VOICE_MAP=Claire=voice_fr_female_1,Marc=voice_fr_male_1,Léa=voice_fr_female_2,Sofia=voice_fr_female_3,Tom=voice_fr_male_2,Inès=voice_fr_female_4,Hugo=voice_fr_male_3,Yanis=voice_fr_male_4,Emma=voice_fr_female_5

# ── Cloudflare R2 (production media storage) ──────────────────
# Create a bucket at dash.cloudflare.com → R2, then generate an API token.
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=ai-radio
# Public URL: enable "Public access" on the bucket in Cloudflare dashboard
R2_PUBLIC_URL=https://pub-REPLACE_ME.r2.dev

# ── Paths (pipeline — local only) ────────────────────────────
PROGRAMME_PATH=./programme.json
MEDIA_DIR=./media
RADIO_ASSETS_DIR=../programme_radio
TIMEZONE=Europe/Paris

# ── Web app (set these in Vercel dashboard, not here) ─────────
# PROGRAMME_URL=https://pub-REPLACE_ME.r2.dev/programme.json

# ── Security ─────────────────────────────────────────────────
# Set to true ONLY behind a corporate proxy intercepting TLS.
# NEVER enable in production.
SSL_NO_VERIFY=false
